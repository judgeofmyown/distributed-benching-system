from Orderbook import *
from random import getrandbits, randint

def main():

    order_book = OrderBook()
    orders = []
    for i in range(50):
        if bool(getrandbtis):
            orders.append(LimitOrder(i, Side.BUY, randint(1, 200), randint(1, 10)))
        else:
            orders.append(LimitOrder(i, Side.SELL, randint(1, 200), randint(1, 10)))
    
    from time import time
    start = time()
    for order in orders:
        order_book.process_order(order)
    end = time()

    totaltime = end - start

    print("Time: " + str(totalTime))
    print("Time per order (us): " + str(1000000*totalTime/numOrders))
    print("Orders per second: " + str(numOrders/totalTime))
    
main()

